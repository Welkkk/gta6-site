<?xml version="1.0" standalone="no"?><!DOCTYPE svg PUBLIC "-//W3C//DTD SVG 1.1//EN" "http://www.w3.org/Graphics/SVG/1.1/DTD/svg11.dtd"><svg width="500px" height="165px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
								<style type="text/css">
									<![CDATA[
										@-webkit-keyframes a {
											0%   	{opacity: 0;}
											45% 	{opacity: 0;}
											55% 	{opacity: 1;}
											90%  	{opacity: 1;}
											100% 	{opacity: 0;}
										} 
										@keyframes a {
											0%   	{opacity: 0;}
											45% 	{opacity: 0;}
											55% 	{opacity: 1;}
											90%  	{opacity: 1;}
											100% 	{opacity: 0;}
										} 
										#o {
											-webkit-animation: a 6.5s infinite; 
											animation: a 6.5s infinite;
										}
									]]>
								</style><image id="b" width="500px" height="165px" xlink:href="data:image/png;base64,"></image><image id="o" width="500px" height="165px" xlink:href="data:image/png;base64,"></image></svg>